function jsonRpcResponse(id: any, result: any) {
  return { jsonrpc: '2.0', id, result }
}

function jsonRpcError(id: any, code: number, message: string) {
  return { jsonrpc: '2.0', id, error: { code, message } }
}

async function callInternal(baseUrl: string, path: string, params: Record<string, string>): Promise<any> {
  const url = new URL(path, baseUrl)
  for (const [k, v] of Object.entries(params)) {
    if (v !== undefined && v !== null) url.searchParams.set(k, String(v))
  }
  const res = await fetch(url.toString(), { cache: 'no-store' })
  return res.json()
}

async function callInternalPost(baseUrl: string, path: string, body: Record<string, unknown>): Promise<any> {
  const url = new URL(path, baseUrl)
  const res = await fetch(url.toString(), {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
    cache: 'no-store',
  })
  return res.json()
}

