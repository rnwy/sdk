// TOOL HANDLERS
// ═══════════════════════════════════════

async function handleNetworkStats(): Promise<any> {
  const [registryRes, tierRes, commerceRes, statsRes] = await Promise.all([
(async () => {
      const results: Record<string, number> = {}
      for (const reg of ['erc8004', 'olas']) {
        const { count } = await supabase.from('computed_agents').select('agent_id', { count: 'exact', head: true }).eq('registry', reg)
        results[reg] = count || 0
      }
      return Object.entries(results).map(([registry, count]) => ({ registry, count }))
    })(),
    // Trust score tier distribution
    supabase.from('computed_agents').select('overall_score').not('overall_score', 'is', null),
    // Commerce totals
    Promise.all([
      supabase.from('commerce_jobs').select('job_id', { count: 'exact', head: true }).eq('protocol', 'olas'),
      supabase.from('commerce_jobs').select('job_id', { count: 'exact', head: true }).eq('protocol', 'virtuals'),
    ]),
    // Global stats
    supabase.from('computed_stats').select('*').eq('id', 'global').limit(1),
  ])

  // Compute tiers from scores
  const tiers = { established: 0, developing: 0, limited: 0, flagged: 0, unscored: 0 }
  if (tierRes.data) {
    for (const row of tierRes.data) {
      const s = row.overall_score
      if (s == null) tiers.unscored++
      else if (s >= 75) tiers.established++
      else if (s >= 51) tiers.developing++
      else if (s >= 30) tiers.limited++
      else tiers.flagged++
    }
  }

  const [olasJobs, virtualsJobs] = commerceRes
  const globalStats = statsRes.data?.[0]

  // Chain distribution
  const chainCounts: Record<string, number> = {}
  if (tierRes.data) {
    // Use a separate query for chain distribution
    const { data: chainRows } = await supabase.from('computed_agents').select('chain_id')
    if (chainRows) {
      for (const row of chainRows) {
        const name = chainIdToName(row.chain_id)
        chainCounts[name] = (chainCounts[name] || 0) + 1
      }
    }
  }

  return {
    totalAgents: globalStats?.total_agents || Object.values(chainCounts).reduce((a, b) => a + b, 0),
    registries: registryRes,
    chains: chainCounts,
    tiers,
    commerce: {
      olasJobs: olasJobs.count || 0,
      virtualsJobs: virtualsJobs.count || 0,
      totalJobs: (olasJobs.count || 0) + (virtualsJobs.count || 0),
    },
    averageAgeDays: globalStats?.average_age_days || null,
    originalOwnerPercentage: globalStats?.original_owner_percentage || null,
  }
}

async function handleCommerceStats(args: any): Promise<any> {
  // Address-based lookup (Virtuals ACP or any address)
  if (args.address) {
    const addr = args.address.toLowerCase()
    const { data: addressStats } = await supabase
      .from('commerce_address_stats')
      .select('*')
      .eq('address', addr)

    if (!addressStats || addressStats.length === 0) {
      return { found: false, address: addr, message: 'No commerce activity found for this address.' }
    }

    // Check for linked agent
    const { data: linked } = await supabase
      .from('linked_addresses')
      .select('agent_id, chain_id, registry, protocol')
      .eq('external_address', addr)
      .limit(1)

    let linkedAgent = null
    if (linked?.[0]) {
      const { data: agentRow } = await supabase
        .from('computed_agents')
        .select('name, overall_score')
        .eq('agent_id', parseInt(linked[0].agent_id))
        .eq('chain_id', linked[0].chain_id)
        .limit(1)
      linkedAgent = {
        id: linked[0].agent_id,
        chain: chainIdToName(linked[0].chain_id),
        registry: linked[0].registry,
        name: agentRow?.[0]?.name || null,
        trustScore: agentRow?.[0]?.overall_score || null,
      }
    }

    return {
      found: true,
      address: addr,
      linkedAgent,
      protocols: addressStats.map((row: any) => ({
        protocol: row.protocol,
        chain: chainIdToName(row.chain_id),
        jobsAsProvider: row.total_jobs_as_provider || 0,
        jobsAsClient: row.total_jobs_as_client || 0,
        jobsAsEvaluator: row.total_jobs_as_evaluator || 0,
      })),
    }
  }

  // Agent-based lookup (requires id + chain)
  if (args.id && args.chain) {
    const chainId = CHAIN_IDS[args.chain]
    if (!chainId) return { error: `Unknown chain: ${args.chain}` }
    const registry = args.registry || 'erc8004'

    const { data: agentStats } = await supabase
      .from('commerce_agent_stats')
      .select('*')
      .eq('agent_id', String(args.id))
      .eq('chain_id', chainId)
      .eq('registry', registry)

    if (!agentStats || agentStats.length === 0) {
      return { found: false, agentId: args.id, chain: args.chain, registry, message: 'No commerce activity linked to this agent.' }
    }

    return {
      found: true,
      agentId: args.id,
      chain: args.chain,
      registry,
      protocols: agentStats.map((row: any) => ({
        protocol: row.protocol,
        totalJobs: row.total_jobs || 0,
        uniqueCounterparties: row.unique_counterparties || 0,
        repeatClientPct: row.repeat_client_pct || 0,
        paymentTotal: row.payment_total || '0',
        firstJob: row.first_job_at,
        lastJob: row.last_job_at,
        circularJobFlag: row.circular_job_flag || false,
      })),
    }
  }

  return { error: 'Provide either address or (id + chain). See tool description.' }
}

async function handleToolCall(baseUrl: string, toolName: string, args: any): Promise<any> {
  switch (toolName) {
    case 'trust_check': {
      const params: Record<string, string> = { id: args.id, chain: args.chain }
      if (args.threshold) params.threshold = String(args.threshold)
      if (args.registry) params.registry = args.registry
      return callInternal(baseUrl, '/api/trust-check', params)
    }
    case 'reviewer_analysis': {
      return callInternal(baseUrl, '/api/reviewer-analysis', { id: args.id, chain: args.chain })
    }
    case 'compare_agents': {
      const params: Record<string, string> = { agents: args.agents }
      if (args.threshold) params.threshold = String(args.threshold)
      return callInternal(baseUrl, '/api/compare', params)
    }
    case 'address_age': {
      const params: Record<string, string> = { address: args.address }
      if (args.chain) params.chain = args.chain
      return callInternal(baseUrl, '/api/address-ages', params)
    }
    case 'network_stats': {
      return handleNetworkStats()
    }
    case 'commerce_stats': {
      return handleCommerceStats(args)
    }
    case 'reviewer_wallet': {
      const params: Record<string, string> = { address: args.address, chain: args.chain }
      params.summary = args.summary === false ? 'false' : 'true'
      return callInternal(baseUrl, '/api/reviewer', params)
    }
    case 'risk_terms': {
      const body: Record<string, unknown> = {
        agent_id: args.agent_id,
        chain: args.chain,
      }
      if (args.registry) body.registry = args.registry
      return callInternalPost(baseUrl, '/api/risk-terms', body)
    }
    default:
      throw new Error(`Unknown tool: ${toolName}`)
  }
}

export async function POST(request: NextRequest) {
  let body: any
  try {
    body = await request.json()
  } catch {
    return NextResponse.json(
      jsonRpcError(null, -32700, 'Parse error'),
      { status: 400 }
    )
  }

  const { jsonrpc, id, method, params } = body

  if (jsonrpc !== '2.0') {
    return NextResponse.json(
      jsonRpcError(id, -32600, 'Invalid Request: jsonrpc must be "2.0"'),
      { status: 400 }
    )
  }

  const baseUrl = new URL(request.url).origin

  switch (method) {
    case 'initialize': {
      return NextResponse.json(jsonRpcResponse(id, {
        protocolVersion: '2024-11-05',
        serverInfo: SERVER_INFO,
        capabilities: {
          tools: { listChanged: false },
        },
      }))
    }

    case 'notifications/initialized': {
      return NextResponse.json(jsonRpcResponse(id, {}))
    }

    case 'tools/list': {
      return NextResponse.json(jsonRpcResponse(id, { tools: TOOLS }))
    }

    case 'tools/call': {
      const toolName = params?.name
      const toolArgs = params?.arguments || {}

      if (!toolName) {
        return NextResponse.json(
          jsonRpcError(id, -32602, 'Invalid params: tool name required'),
          { status: 400 }
        )
      }

      const tool = TOOLS.find(t => t.name === toolName)
      if (!tool) {
        return NextResponse.json(
          jsonRpcError(id, -32602, `Unknown tool: ${toolName}. Available: ${TOOLS.map(t => t.name).join(', ')}`),
          { status: 400 }
        )
      }

      try {
        const result = await handleToolCall(baseUrl, toolName, toolArgs)
        return NextResponse.json(jsonRpcResponse(id, {
          content: [
            { type: 'text', text: JSON.stringify(result, null, 2) },
          ],
        }))
      } catch (err: any) {
        return NextResponse.json(
          jsonRpcError(id, -32000, err.message || 'Tool execution failed'),
          { status: 500 }
        )
      }
    }

    default: {
      return NextResponse.json(
        jsonRpcError(id, -32601, `Method not found: ${method}. Available: initialize, tools/list, tools/call`),
        { status: 400 }
      )
    }
  }
}

