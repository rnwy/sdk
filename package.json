// CHAIN HELPERS
// ═══════════════════════════════════════

const CHAIN_IDS: Record<string, number> = {
  ethereum: 1, base: 8453, bnb: 56, monad: 143, megaeth: 4326,
  gnosis: 100, celo: 42220, arbitrum: 42161, avalanche: 43114,
  polygon: 137, optimism: 10,
}

function chainIdToName(chainId: number): string {
  return Object.entries(CHAIN_IDS).find(([, id]) => id === chainId)?.[0] || 'unknown'
}

